{
  "$schema": "./types.ts",
  "version": "0.1.0",
  "description": "Canonical glossary of architectural / construction symbols used during detection. Seeded from AIA, NCS, IEC 60617, ISO 7000. Grows with community variants.",
  "entries": [
    {
      "id": "wall_interior_partition",
      "category": "wall",
      "common_names": ["interior partition", "non-load-bearing wall", "stud wall"],
      "represents": "Standard interior partition wall, typically wood or metal stud, 4-6in thick",
      "appearance": { "shape": "polyline", "stroke_style": "double_solid" },
      "default_height_in": 96,
      "standards": ["AIA"]
    },
    {
      "id": "wall_load_bearing",
      "category": "wall",
      "common_names": ["load-bearing wall", "bearing wall", "structural wall"],
      "represents": "Wall carrying structural load. Hatched in plan, often thicker than partitions.",
      "appearance": { "shape": "polyline", "stroke_style": "solid_thick" },
      "default_height_in": 96
    },
    {
      "id": "wall_fire_rated",
      "category": "wall",
      "common_names": ["fire-rated wall", "rated assembly", "1-hour wall"],
      "represents": "Wall with fire-resistance rating (e.g. 1-hour, 2-hour). Tagged with rating.",
      "appearance": { "shape": "polyline", "stroke_style": "solid_thick", "has_text": true }
    },
    {
